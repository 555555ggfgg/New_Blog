{
  "name": "blog-system",
  "version": "1.0.0",
  "description": "Blog system with client and server",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "hitokoto-sdk",
    "scratch-editor",
    "vue-hitokoto"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "dev:client": "pnpm run dev --filter=client",
    "dev:server": "pnpm run dev --filter=server",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint --if-present",
    "test": "pnpm -r run test --if-present",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
